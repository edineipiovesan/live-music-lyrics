# live-music-lyrics configuration
# Copy this file to .env and fill in required values.
# Env vars already set in the shell take precedence over values here.

# ── Required ──────────────────────────────────────────────────────────────────
# AudD API key — get a free key at https://dashboard.audd.io/
AUDD_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Log level for the application: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Set to false to disable auto-opening the browser on startup
OPEN_BROWSER=true

# ── Audio capture ─────────────────────────────────────────────────────────────
# Sample rate in Hz (AudD works best at 16000)
SAMPLE_RATE=16000
# Duration of each audio chunk sent to AudD (seconds)
CHUNK_DURATION_S=5
# Max number of unprocessed audio chunks kept in memory
AUDIO_QUEUE_SIZE=10

# ── Recognition loop ──────────────────────────────────────────────────────────
# Start listening for the next song this many seconds before the current one ends
LISTEN_BEFORE_END_S=5
# Re-check interval (seconds) when song duration is unknown
FALLBACK_INTERVAL_S=30

# ── UI / history ──────────────────────────────────────────────────────────────
# Maximum number of songs kept in the "Recently Played" list
HISTORY_MAX=20
# Seconds each fact is displayed before rotating to the next
FACT_ROTATION_S=30

# ── HTTP timeouts (seconds) ───────────────────────────────────────────────────
AUDD_TIMEOUT=15
LYRICS_TIMEOUT=10
ALBUM_TIMEOUT=10
FACTS_TIMEOUT=8
